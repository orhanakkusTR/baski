# ---- Sanity (CMS) ----
# Create a project at https://www.sanity.io/manage, then paste its id here.
# The site is designed to build without these — queries return empty arrays
# and the mock projects in src/lib/mock-projects.ts are used as a fallback.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only token with write scope. Required only for draft preview and
# the revalidation webhook route — NOT for the public read client.
SANITY_API_TOKEN=

# Shared secret used to authenticate the /api/revalidate webhook.
SANITY_REVALIDATE_SECRET=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@awab.se
CONTACT_EMAIL_FROM=noreply@awab.se

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://awab.se
